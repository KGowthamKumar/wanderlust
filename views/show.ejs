<% layout("/layouts/boilerplates.ejs") %>
<div class="eachone">  
<h3>LISTING DETAILS:</h3>
     <div class="seperate-image">
        <img src="<%= listing.image.url %>" alt="" width="350px" height="350px">
    </div>
    <div>
    <ul>
      <li><b>Created by:</b><%= listing.owner.username %></li>
        <li><%= listing.title %></li>
        <div class="card-body">
          <p class="card-text"> <li><%= listing.description %></li></p>
        </div>
        <li>&#8377;<%= listing.price.toLocaleString("en-IN") %></li>
        <li><%= listing.location %></li>
        <li><%= listing.country %></li>
    </ul>
</div>

<% if(currUser && listing.owner._id.equals(currUser._id)){ %>
<div>
    <a href="/listings/<%= listing._id %>/edit"
       class="btn btn-success">
       Edit this Listing
    </a>

    <br>

    <form method="POST"
          action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="delete">
            Delete this Listing
        </button>
    </form>
</div>
 <% } %>
   <!-- </form><br>
   </form> -->
    <hr/>
    <% if(currUser) {%>
   <div class="col-8 offset-3">
     <h4>Leave Your Review</h4>
  <form action="/listings/<%= listing.id %>/reviews" method="post" novalidate class="needs-validation">
  <label for="rating" class="form-label">Rating</label>      
  <fieldset class="starability-slot">
  <legend>First rating:</legend>
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
  <input type="radio" id="second-rate1" name="review[rating]" value="1" />
  <label for="second-rate1" title="Terrible">1 star</label>
  <input type="radio" id="second-rate2" name="review[rating]" value="2" />
  <label for="second-rate2" title="Not good">2 stars</label>
  <input type="radio" id="second-rate3" name="review[rating]" value="3" />
  <label for="second-rate3" title="Average">3 stars</label>
  <input type="radio" id="second-rate4" name="review[rating]" value="4" />
  <label for="second-rate4" title="Very good">4 stars</label>
  <input type="radio" id="second-rate5" name="review[rating]" value="5" />
  <label for="second-rate5" title="Amazing">5 stars</label>
</fieldset>
          <div class="mb-3 mt-3">
            <label for="comment" class="form-label">comment</label>
            <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
              <div class="invalid-feedback">
            <p>*please add some comments for review</p>
          </div>
          </div>
        <button class="btn btn-outline-dark">submit</button>
     </form>
   </div>
   <% } %>
   <h3>REVIEWS</h3>
<ul>
<div class="row">
<% for(review of listing.reviews){ %>
  <div class="card col-6" style="width: 18rem;">
  <div class="card-body">
    <h5 class="card-title"><%= review.author.username %></h5>
        <p class="starability-result" data-rating="<%= review.rating %>"></p>
    <p class="card-text"><%= review.comment %></p>
  </div> 
  <form action="/listings/<%= listing._id %>/reviews/<%=review._id%>?_method=DELETE" method="post" >
    <button class="button btn-dark">Delete</button>
  </form>
</div>
      <% } %>
 </div>
</ul>

