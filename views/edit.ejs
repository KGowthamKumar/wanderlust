<% layout("/layouts/boilerplates.ejs") %>
<h1>Edit This Listing <%= listing.title  %></h1>
<form method="post" action="/listings/<%= listing._id %>?_method=PUT" enctype="multipart/form-data">

    <input type="text" name="listing[title]" value="<%= listing.title %>"><br><br>

    <textarea name="listing[description]"><%= listing.description %></textarea><br><br>
     <div>
        <h1>original image</h1>
        <img src="<%= originalimage %>" >
     </div>
    <input type="file" name="listing[image]" value="<%= listing.image %>"><br><br>

    <input type="number" name="listing[price]" value="<%= listing.price %>"><br><br>

    <input type="text" name="listing[location]" value="<%= listing.location %>"><br><br>

    <input type="text" name="listing[country]" value="<%= listing.country %>"><br><br>

    <button>edit</button>
</form>
